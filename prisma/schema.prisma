// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// 共用表
// ----------------------------------------------------------------------

model User {
  id Int @id @default(autoincrement()) @map("user_id")

  email    String  @unique
  password String?

  nickname String?
  fullName String? @map("full_name")
  avatar   String?
  safety   Int?    @default(0)

  description String?
  point       Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 旅行筆記
  Likes         Like[]
  Posts         Post[]
  MessageBoards MessageBoard[]

  // 行程規劃
  Expenses        Expense[]
  PackingItems    PackingItem[]
  TripPlans       TripPlan[]
  TripPlanDetails TripPlanDetail[]

  // 住宿交通
  Reviews                Review[]
  FavoriteAccommodations FavoriteAccommodation[]
  Bookings               Booking[]

  // 美食景點
  Favorites Favorite[]
  Comments  Comment[]
  Ranks     Rank[]
  Histories History[]

  // 尋找旅伴
  MessagesSent     Message[] @relation("MessageSender")
  MessagesReceived Message[] @relation("MessageReceiver")

  FriendshipsUser   Friendship[] @relation("UserFriendships")
  FriendshipsFriend Friendship[] @relation("FriendFriendships")

  RoomMembers       RoomMember[]
  Itineraries       Itinerary[]
  UserItineraries   UserItinerary[]
  ItineraryComments ItineraryComment[]

  // 商城
  Orders     Order[]
  Carts      Cart[]
  PointsLogs PointsLog[]
  LoginLogs  LoginLog[]

  //旅行邀約
  sentInvitations     ItineraryInvitation[] @relation("InvitationSender")
  receivedInvitations ItineraryInvitation[] @relation("InvitationReceiver")

  @@map("users")
}

model City {
  id   Int    @id @default(autoincrement()) @map("city_id")
  name String @unique

  // m2
  TripPlans TripPlan[] @relation("TripPlanToCity")

  // m3
  Accommodations Accommodation[]

  //m4
  Places Place[]

  @@map("cities")
}

// ----------------------------------------------------------------------
// m1 旅行筆記模組
// ----------------------------------------------------------------------

// 地點表 (Location)
model Location {
  id Int @id @default(autoincrement()) @map("location_id")

  city String?

  createdAt DateTime @default(now()) @map("created_at")

  Posts Post[]

  @@map("locations")
}

// 文章表 (Post)
model Post {
  // PK
  id Int @id @default(autoincrement()) @map("post_id")

  userId     Int @map("user_id")
  locationId Int @map("location_id")

  title   String @db.VarChar(200) // 標題
  content String @db.Text // 內容

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Location Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  Likes        Like[]
  Photos       Photo[]
  MessageBoard MessageBoard[]

  @@index([userId])
  @@index([locationId])
  @@map("posts")
}

// 讚表 (Like)
model Like {
  // PK
  id Int @id @default(autoincrement()) @map("like_id")

  userId Int @map("user_id")
  postId Int @map("post_id")

  createdAt DateTime @default(now()) @map("created_at")

  User User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Post Post @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, postId])
  @@index([postId])
  @@map("likes")
}

// 照片表 (Photo)
model Photo {
  // PK
  id Int @id @default(autoincrement()) @map("photo_id")

  postId Int @map("post_id")

  url String @db.VarChar(255) // 照片 URL

  createdAt DateTime @default(now()) @map("created_at")

  Post Post @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([postId])
  @@map("photos")
}

// 留言板表 (MessageBoard)
model MessageBoard {
  // PK
  id Int @id @default(autoincrement()) @map("message_board_id")

  // 欄位
  userId   Int?    @map("user_id") // 使用者 ID（可為空）
  postId   Int     @map("post_id")
  username String? @db.VarChar(255) // 使用者名稱
  content  String? @db.VarChar(500) // 留言內容

  createdAt DateTime @default(now()) @map("created_at")

  User User? @relation(fields: [userId], references: [id])
  Post Post  @relation(fields: [postId], references: [id])

  @@map("message_boards")
}

// ----------------------------------------------------------------------
// m2 行程規劃模組
// ----------------------------------------------------------------------
// ----------------- TripPlan  -----------------
model TripPlan {
  id     Int     @id @default(autoincrement()) @map("trip_plan_id")
  userId Int     @map("user_id")
  title  String
  type   String? // 行程類型（獨旅/朋友/情侶/家族）

  // ✅ 目的地外鍵：關聯 City
  destinationId Int?  @map("destination_id")
  Destination   City? @relation("TripPlanToCity", fields: [destinationId], references: [id], onDelete: SetNull)

  // ✅ 多對多關聯 (景點 / 住宿)
  Places         TripPlanPlace[]
  Accommodations TripPlanAccommodation[]

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  url       String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tripPlanListId Int?          @map("trip_plan_list_id")
  TripPlanList   TripPlanList? @relation(fields: [tripPlanListId], references: [id])

  User           User             @relation(fields: [userId], references: [id])
  Expense        Expense[]
  TripPlanDetail TripPlanDetail[]
  PackingItem    PackingItem[]

  @@map("trip_plans")
}

// --------- 行程內包含的景點 ----------
model TripPlanPlace {
  id         Int @id @default(autoincrement()) @map("trip_plan_place_id")
  tripPlanId Int @map("trip_plan_id")
  placeId    Int @map("place_id")

  TripPlan TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  Place    Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([tripPlanId, placeId]) // 一個行程同一景點只能加一次
  @@map("trip_plan_places")
}

// ------------- 行程內住宿清單 -----------
model TripPlanAccommodation {
  id              Int @id @default(autoincrement()) @map("trip_plan_accommodation_id")
  tripPlanId      Int @map("trip_plan_id")
  accommodationId Int @map("accommodation_id")

  TripPlan      TripPlan      @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  Accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([tripPlanId, accommodationId])
  @@map("trip_plan_accommodations")
}

// ----------------- TripPlanList  -----------------

model TripPlanList {
  id        Int        @id @default(autoincrement()) @map("trip_plan_list_id")
  userId    Int        @map("user_id")
  avatar    String? //封面照
  TripPlans TripPlan[]

  @@map("trip_plan_lists")
}

// ----------------- TripPlanDetail  -----------------
model TripPlanDetail {
  id         Int      @id @default(autoincrement()) @map("trip_plan_detail_id")
  TripPlanId Int      @map("trip_plan_id")
  userId     Int      @map("user_id")
  title      String
  order      Int //行程拖曳編輯
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  address    String
  stayHour   Int      @default(0) @map("stay_hour")
  stayMin    Int      @default(0) @map("stay_min")
  type       String? // spot / hotel / food/ custom
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  url        String   @map("image_url")

  tripPlanDetailListId Int?                @map("trip_plan_list_id")
  TripPlanDetailList   TripPlanDetailList? @relation(fields: [tripPlanDetailListId], references: [id])

  User     User      @relation(fields: [userId], references: [id])
  TripPlan TripPlan? @relation(fields: [TripPlanId], references: [id])

  @@map("trip_plan_details")
}

// ----------------- TripPlanDetailList  -----------------
model TripPlanDetailList {
  id         Int     @id @default(autoincrement()) @map("trip_plan_detail_list_id")
  TripPlanId Int     @map("trip_plan_id")
  userId     Int     @map("user_id")
  avatar     String?

  TripPlanDetails TripPlanDetail[] // 多筆詳細行程

  @@map("trip_plan_detail_lists")
}

//記帳分類(美食、住宿、交通、購物、票券)
model ExpenseType {
  id   Int    @id @default(autoincrement()) @map("expense_type_id")
  name String @unique

  Expenses Expense[]

  @@map("expense_types")
}

//記帳內容
model Expense {
  id          Int      @id @default(autoincrement()) @map("expense_id")
  tripPlanId  Int      @map("trip_plan_id") // 對應 UserTripPlan.id，型別改為 Int
  userId      Int      @map("user_id")
  title       String
  amount      Float //Double
  typeId      Int?     @map("type_id") // 可為 null
  area        String?
  expenseDate DateTime @default(now()) @map("expense_date") //前端顯示日期
  createdAt   DateTime @default(now()) @map("created_at") //資料庫顯示
  isChecked   Boolean  @default(false) @map("is_checked") //for刪除給API使用 

  User     User         @relation(fields: [userId], references: [id])
  TripPlan TripPlan?    @relation(fields: [tripPlanId], references: [id])
  Type     ExpenseType? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  @@map("expenses")
}

//行李清單分類
model PackingItemTemplate {
  id           Int           @id @default(autoincrement()) @map("packing_item_template_id")
  name         String        @unique
  PackingItems PackingItem[]
}

//行李清單明細
model PackingItem {
  id         Int     @id @default(autoincrement()) @map("packing_item_id")
  TripPlanId Int     @map("trip_plan_id")
  userId     Int     @map("user_id")
  templateId Int?    @map("template_id") // 對應模板 ID 
  name       String
  isChecked  Boolean @default(false) @map("is_checked")

  User                User                 @relation(fields: [userId], references: [id])
  TripPlan            TripPlan?            @relation(fields: [TripPlanId], references: [id])
  PackingItemTemplate PackingItemTemplate? @relation(fields: [templateId], references: [id])

  @@map("packing_items")
}

// ----------------------------------------------------------------------
// m3 住宿交通模組
// ----------------------------------------------------------------------

model Accommodation {
  id Int @id @default(autoincrement()) @map("accommodation_id")

  typeId            Int               @default(1) @map("type_id")
  accommodationType AccommodationType @relation(fields: [typeId], references: [id])

  cityId Int  @map("city_id")
  City   City @relation(fields: [cityId], references: [id])

  name        String
  address     String
  description String? @db.Text

  latitude     Float?
  longitude    Float?
  checkInTime  String? @map("check_in_time")
  checkOutTime String? @map("check_out_time")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  Contacts               Contact[]
  RoomTypes              RoomType[]
  Reviews                Review[]
  Favorites              FavoriteAccommodation[]
  Amenities              AccommodationAmenity[]
  Bookings               Booking[]
  Images                 AccommodationImage[]
  TripPlanAccommodations TripPlanAccommodation[]

  @@index([cityId])
  @@map("accommodations")
}

model AccommodationType {
  id   Int    @id @default(autoincrement()) @map("type_id")
  name String @unique

  Accommodations Accommodation[]

  @@map("accommodation_types")
}

model Contact {
  id Int @id @default(autoincrement()) @map("contact_id")

  accommodationId Int           @map("accommodation_id")
  Accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  type        String
  value       String
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contacts")
}

model RoomType {
  id Int @id @default(autoincrement()) @map("room_type_id")

  accommodationId Int           @map("accommodation_id")
  Accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  name        String
  description String?
  basePrice   Float   @map("base_price")
  maxCapacity Int     @map("max_capacity")
  totalRooms  Int     @map("total_rooms")

  bedType String? @map("bed_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  Amenities    RoomTypeAmenity[]
  Rates        RoomRate[]
  Inventories  RoomInventory[]
  BookingItems BookingItem[]

  @@map("room_types")
}

model Amenity {
  id   Int     @id @default(autoincrement()) @map("amenity_id")
  name String  @unique
  type String?

  Accommodations AccommodationAmenity[]
  RoomTypes      RoomTypeAmenity[]

  @@map("amenities")
}

model AccommodationImage {
  id Int @id @default(autoincrement()) @map("image_id")

  accommodationId Int           @map("accommodation_id")
  Accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  url       String  @map("image_url")
  caption   String?
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(1) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accommodation_images")
}

model AccommodationAmenity {
  id Int @id @default(autoincrement())

  accommodationId Int           @map("accommodation_id")
  Accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  amenityId Int     @map("amenity_id")
  Amenity   Amenity @relation(fields: [amenityId], references: [id])

  @@unique([accommodationId, amenityId])
  @@map("accommodation_amenities")
}

model RoomTypeAmenity {
  id Int @id @default(autoincrement())

  roomTypeId Int      @map("room_type_id")
  RoomType   RoomType @relation(fields: [roomTypeId], references: [id])

  amenityId Int     @map("amenity_id")
  Amenity   Amenity @relation(fields: [amenityId], references: [id])

  @@unique([roomTypeId, amenityId])
  @@map("room_type_amenities")
}

model FavoriteAccommodation {
  id Int @id @default(autoincrement()) @map("favorite_id")

  userId Int  @map("user_id")
  User   User @relation(fields: [userId], references: [id])

  accommodationId Int           @map("accommodation_id")
  Accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  addedAt DateTime @default(now()) @map("added_at")

  @@unique([userId, accommodationId])
  @@map("favorite_accommodations")
}

model RoomRate {
  id Int @id @default(autoincrement()) @map("rate_id")

  roomTypeId Int      @map("room_type_id")
  RoomType   RoomType @relation(fields: [roomTypeId], references: [id])

  date       DateTime @map("date")
  dailyPrice Float    @map("daily_price")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([roomTypeId, date])
  @@map("room_rates")
}

model RoomInventory {
  id Int @id @default(autoincrement()) @map("inventory_id")

  roomTypeId Int      @map("room_type_id")
  RoomType   RoomType @relation(fields: [roomTypeId], references: [id])

  date           DateTime @map("date")
  totalCount     Int      @map("total_count")
  availableCount Int      @map("available_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([roomTypeId, date])
  @@map("room_inventories")
}

model Booking {
  id Int @id @default(autoincrement()) @map("booking_id")

  userId Int  @map("user_id")
  User   User @relation(fields: [userId], references: [id])

  accommodationId Int           @map("accommodation_id")
  Accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  checkInDate  DateTime @map("check_in_date")
  checkOutDate DateTime @map("check_out_date")
  totalAmount  Decimal  @map("total_amount") @db.Decimal(10, 2)
  status       String   @default("Pending")

  guestName    String  @map("guest_name")
  guestContact String? @map("guest_contact")

  bookingDate      DateTime  @default(now()) @map("booking_date")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  cancellationDate DateTime? @map("cancellation_date")

  Items BookingItem[]

  Review Review?

  @@map("bookings")
}

model BookingItem {
  id Int @id @default(autoincrement()) @map("item_id")

  bookingId Int     @map("booking_id")
  Booking   Booking @relation(fields: [bookingId], references: [id])

  roomTypeId Int      @map("room_type_id")
  RoomType   RoomType @relation(fields: [roomTypeId], references: [id])

  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)

  @@map("booking_items")
}

model Review {
  id Int @id @default(autoincrement()) @map("review_id")

  accommodationId Int           @map("accommodation_id")
  Accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  userId Int  @map("user_id")
  User   User @relation(fields: [userId], references: [id])

  bookingId Int?     @unique @map("booking_id")
  Booking   Booking? @relation(fields: [bookingId], references: [id])

  ratingScore Int     @map("rating_score")
  comment     String? @db.Text

  reviewDate DateTime  @default(now()) @map("review_date")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("reviews")
}

// ----------------------------------------------------------------------
// m4 美食景點模組
// ----------------------------------------------------------------------

// 地點表 (Place) - 美食／景點
model Place {
  id        Int     @id @default(autoincrement()) @map("place_id")
  type      String  @map("type") @db.VarChar(20) // "food" 或 "spot"
  name      String  @map("name") @db.VarChar(100)
  introduce String? @map("introduce") @db.Text
  contact   String? @map("contact") @db.VarChar(50)
  region    String? @map("region") @db.VarChar(100) // 子區域
  address   String? @map("address") @db.VarChar(150)
  latitude  Float?  @map("latitude")
  longitude Float?  @map("longitude")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at") // 使用 @updatedAt

  // FK (cityId, city)
  cityId Int?  @map("city_id")
  City   City? @relation(fields: [cityId], references: [id], onDelete: SetNull)

  // 🔹 回指關聯
  Photos         PlacePhoto[]
  Favorites      Favorite[]
  Comments       Comment[]
  Ranks          Rank[]
  Histories      History[]
  OpeningHours   OpeningHour[]
  TripPlanPlaces TripPlanPlace[]

  // 🔹 索引
  @@index([type, region])
  @@map("places")
}

// 地點照片表 (PlacePhoto)
model PlacePhoto {
  id Int @id @default(autoincrement()) @map("photo_id")

  // FK
  placeId Int @map("place_id")

  // 欄位
  url       String @map("url") @db.VarChar(255)
  sortOrder Int    @default(0) @map("sort_order") // 顯示順序

  Place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  // 加速查詢／排序
  @@index([placeId, sortOrder])
  @@map("place_photos")
}

// 收藏表 (Favorite)
model Favorite {
  id Int @id @default(autoincrement()) @map("favorite_id")

  // FK
  userId  Int @map("user_id")
  placeId Int @map("place_id")

  createdAt DateTime @default(now()) @map("created_at")

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  // 同一使用者對同地點只收藏一次
  @@unique([userId, placeId])
  @@map("favorites")
}

// 評論表 (Comment)
model Comment {
  id Int @id @default(autoincrement()) @map("comment_id")

  // FK
  userId  Int @map("user_id")
  placeId Int @map("place_id")

  // 欄位
  content   String?  @map("content") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at") // 使用 @updatedAt

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  // 限制一個使用者對同地點一則留言（可移除）
  @@unique([userId, placeId])
  @@index([placeId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("comments")
}

// 評分表 (Rank)
model Rank {
  id Int @id @default(autoincrement()) @map("rank_id")

  // FK
  userId  Int @map("user_id")
  placeId Int @map("place_id")

  // 欄位
  score     Int      @map("score") // 1~5 分
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at") // 使用 @updatedAt

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([placeId, updatedAt(sort: Desc)])
  @@map("ranks")
}

// 瀏覽紀錄表 (History)
model History {
  id Int @id @default(autoincrement()) @map("history_id")

  // FK
  userId  Int @map("user_id")
  placeId Int @map("place_id")

  // 欄位
  lastViewedAt DateTime @default(now()) @updatedAt @map("last_viewed_at")

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  // 一人一地點一筆（時間更新）
  @@unique([userId, placeId])
  @@index([userId, lastViewedAt(sort: Desc)])
  @@map("histories")
}

// 營業時段表
model OpeningHour {
  id        Int      @id @default(autoincrement()) @map("opening_hour_id")
  placeId   Int      @map("place_id")
  weekday   Int      @map("weekday") @db.TinyInt // 0=Sun, 6=Sat
  openTime  DateTime @map("open_time") @db.Time(0) // 24h, e.g. 11:00:00
  closeTime DateTime @map("close_time") @db.Time(0) // 24h, e.g. 21:30:00
  isClosed  Boolean  @default(false) @map("is_closed") // 公休

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  Place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, weekday])
  @@index([placeId, weekday])
  @@map("opening_hours")
}

// ----------------------------------------------------------------------
// m5 尋找旅伴模組
// ----------------------------------------------------------------------

// ----------------- Message -----------------
model Message {
  id Int @id @default(autoincrement()) @map("message_id")

  roomId     Int?    @map("room_id")
  receiverId Int?    @map("receiver_id")
  senderId   Int     @map("sender_id")
  isRead     Boolean @default(false) @map("is_read")

  content     String @db.Text
  messageType String @map("message_type")

  createdAt DateTime @default(now()) @map("created_at") // 💡 修正：添加 @default(now())
  updatedAt DateTime @updatedAt @map("updated_at") // 💡 修正：添加 @updatedAt

  Room     Room? @relation(fields: [roomId], references: [id])
  Sender   User  @relation("MessageSender", fields: [senderId], references: [id])
  Receiver User? @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@map("messages")
}

// ----------------- Room -----------------
model Room {
  id Int @id @default(autoincrement()) @map("room_id")

  roomName String @map("room_name")

  createdAt DateTime @default(now()) @map("created_at") // 💡 修正：添加 @default(now())

  Messages Message[]
  Members  RoomMember[]

  Itineraries Itinerary[]

  @@map("rooms")
}

// ----------------- RoomMember -----------------
model RoomMember {
  id       Int      @id @default(autoincrement()) @map("room_member_id")
  roomId   Int      @map("room_id")
  userId   Int      @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at") // 💡 修正：添加 @default(now())

  Room Room @relation(fields: [roomId], references: [id])
  User User @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("room_members")
}

// ----------------- Friendship -----------------
model Friendship {
  id        Int      @id @default(autoincrement()) @map("friendship_id")
  userId    Int      @map("user_id")
  friendId  Int      @map("friend_id")
  status    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  User   User @relation("UserFriendships", fields: [userId], references: [id])
  Friend User @relation("FriendFriendships", fields: [friendId], references: [id])

  @@map("friendships")
}

// ----------------- UserItinerary -----------------
model UserItinerary {
  id     Int @id @default(autoincrement()) @map("user_itinerary_id")
  userId Int @map("user_id")

  itineraryId Int @map("itinerary_id")

  User      User       @relation(fields: [userId], references: [id])
  Itinerary Itinerary? @relation(fields: [itineraryId], references: [id])

  @@map("user_itineraries")
}

// ----------------- Itinerary  -----------------
model Itinerary {
  id     Int    @id @default(autoincrement()) @map("itinerary_id")
  userId Int    @map("user_id")
  title  String
  roomId Int?   @map("room_id")

  createdAt DateTime @default(now()) @map("created_at") // 💡 修正：添加 @default(now())
  updatedAt DateTime @updatedAt @map("updated_at") // 💡 修正：添加 @updatedAt

  area   String
  status Int    @default(1)
  figure Int

  User User  @relation(fields: [userId], references: [id])
  Room Room? @relation(fields: [roomId], references: [id])

  Days                 ItineraryDay[]
  Images               ItineraryImage[]
  UserLinked           UserItinerary[]
  ItineraryComments    ItineraryComment[]
  Article              Article?
  itineraryInvitations ItineraryInvitation[]

  @@map("itineraries")
}

// ----------------- ItineraryDay  -----------------
model ItineraryDay {
  id          Int      @id @default(autoincrement()) @map("itinerary_day_id")
  itineraryId Int      @map("itinerary_id") // 保留原 map 名稱，修正欄位名
  dayDate     DateTime @map("day_date")
  startTime   DateTime @map("start_time")
  status      Int

  Itinerary Itinerary @relation(fields: [itineraryId], references: [id])

  Nodes     ItineraryNode[]
  StayNodes StayNode[]

  @@map("itinerary_days")
}

// ----------------- ItineraryNode  -----------------
model ItineraryNode {
  id             Int @id @default(autoincrement()) @map("itinerary_node_id")
  itineraryDayId Int @map("itinerary_day_id") // 保留原 map 名稱，修正欄位名
  // placeId          Int @map("place_id")
  // googleMapPlaceId Int @map("google_map_place_id")

  durationMinutes Int @map("duration_minutes")
  order           Int @default(0)
  status          Int

  // ✅ 新增連到 Attraction 的外鍵（資料庫欄位）
  attractionId Int? @map("attraction_id")

  Day ItineraryDay @relation(fields: [itineraryDayId], references: [id])

  // ✅ 正確關聯 Attraction
  Attraction Attraction? @relation(fields: [attractionId], references: [id])

  // GoogleMapPlace GoogleMapPlace @relation(fields: [googleMapPlaceId], references: [id])

  @@map("itinerary_nodes")
}

// ----------------- ItineraryImage  -----------------
model ItineraryImage {
  id          Int    @id @default(autoincrement()) @map("itinerary_image_id")
  itineraryId Int    @map("itinerary_id")
  imageName   String @map("image_name")

  Itinerary Itinerary @relation(fields: [itineraryId], references: [id])

  @@map("itinerary_images")
}

// ----------------- StayNode -----------------
model StayNode {
  id              Int @id @default(autoincrement()) @map("stay_node_id")
  itineraryDayId  Int @map("itinerary_day_id")
  accommodationId Int @map("accommodation_id")
  status          Int

  Day ItineraryDay @relation(fields: [itineraryDayId], references: [id])

  @@map("stay_nodes")
}

// ----------------- ItineraryComment  -----------------
model ItineraryComment {
  id          Int    @id @default(autoincrement()) @map("itinerary_comment_id")
  itineraryId Int    @map("itinerary_id")
  senderId    Int    @map("sender_id")
  content     String @db.Text

  createdAt DateTime @default(now()) @map("created_at") // 💡 修正：添加 @default(now())
  updatedAt DateTime @updatedAt @map("updated_at") // 💡 修正：添加 @updatedAt

  Itinerary Itinerary @relation(fields: [itineraryId], references: [id])
  Sender    User      @relation(fields: [senderId], references: [id])

  @@map("itinerary_comments")
}

// ----------------- GoogleMapPlace  -----------------
model GoogleMapPlace {
  id               Int      @id @default(autoincrement()) @map("google_map_place_id")
  placeId          String   @unique @map("place_id") // Google 提供的 place_id
  name             String
  formattedAddress String   @map("formatted_address")
  lat              Float
  lng              Float
  photoReference   String?  @map("photo_reference") @db.Text // 可選，若有照片
  createdAt        DateTime @default(now()) @map("created_at")

  // ItineraryNodes ItineraryNode[]

  @@map("google_map_places")
}

// ----------------- Article  -----------------
model Article {
  id          Int      @id @default(autoincrement()) @map("article_id")
  itineraryId Int      @unique @map("itinerary_id")
  title       String
  content     String   @db.Text
  publishedAt DateTime @default(now()) @map("published_at")

  Itinerary Itinerary @relation(fields: [itineraryId], references: [id])

  @@map("articles")
}

// ----------------- ItineraryInvitation  -----------------
model ItineraryInvitation {
  id          Int      @id @default(autoincrement())
  itineraryId Int      @map("itinerary_id")
  senderId    Int      @map("sender_id")
  receiverId  Int      @map("receiver_id")
  status      Int      @default(0) // 0: pending, 1: accepted, 2: rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 關聯（假設有 User 與 Itinerary 表）
  itinerary Itinerary @relation(fields: [itineraryId], references: [id])
  sender    User      @relation("InvitationSender", fields: [senderId], references: [id])
  receiver  User      @relation("InvitationReceiver", fields: [receiverId], references: [id])

  @@map("itinerary_invitation")
}

// ----------------- Attraction  -----------------
model Attraction {
  id         Int     @id @default(autoincrement())
  name       String?
  nameZh     String? @map("name_Zh")
  tourism    String?
  natural    String?
  historic   String?
  artistName String? @map("artist_name")

  lng Float
  lat Float

  addrCity        String? @map("addr_city")
  addrCountry     String? @map("addr_country")
  addrDistrict    String? @map("addr_district")
  addrHousenumber String? @map("addr_housenumber")
  addrPostcode    String? @map("addr_postcode")
  addrProvince    String? @map("addr_province")
  addrStreet      String? @map("addr_street")
  addrFull        String? @map("addr_full")

  image String?

  // ✅ 修正為 ItineraryNode[]（你之前拼錯 ItinerarieNode）
  nodes ItineraryNode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------
// m6 商城模組
// -------------------------------------------------------

//產品主表
model Product {
  id          Int    @id @default(autoincrement()) @map("product_id")
  productName String @map("product_name")
  keyword     String
  description String

  ProductVariants ProductVariant[]
  ProductPics     ProductPic[]

  @@map("products")
}

//產品細項 標價 庫存
model ProductVariant {
  id          Int    @id @default(autoincrement()) @map("variant_id")
  productId   Int    @map("product_id")
  variantName String @map("variant_name") @db.VarChar(255)
  price       Int
  stock       Int

  Product Product @relation(fields: [productId], references: [id])

  OrderDetails OrderDetail[]
  Carts        Cart[]

  @@map("product_variants")
}

//產品圖片
model ProductPic {
  picId     Int    @id @default(autoincrement()) @map("pic_id")
  src       String @db.VarChar(255)
  productId Int    @map("product_id")

  Product Product @relation(fields: [productId], references: [id])

  @@map("product_pics")
}

//訂單主表
model Order {
  id         Int    @id @default(autoincrement()) @map("order_id")
  userId     Int    @map("user_id")
  orderTotal Int    @map("order_total")
  tradeId    String @map("trade_id")

  User User @relation(fields: [userId], references: [id])

  OrderDetails OrderDetail[]

  @@map("orders")
}

//訂單細項
model OrderDetail {
  id            Int @id @default(autoincrement()) @map("details_id")
  orderId       Int @map("order_id")
  variantId     Int @map("variant_id")
  productAmount Int @map("product_amount")
  subTotal      Int @map("sub_total")

  Order          Order          @relation(fields: [orderId], references: [id])
  ProductVariant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_details")
}

//購物車
model Cart {
  id        Int @id @default(autoincrement()) @map("cart_id")
  userId    Int @map("user_id")
  variantId Int @map("variant_id")
  amount    Int @default(1) // 💡 修正：添加預設值

  User           User           @relation(fields: [userId], references: [id])
  ProductVariant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([userId, variantId]) // 💡 修正：添加唯一約束 (同一用戶同一規格只一條記錄)
  @@map("carts")
}

//積分變化紀錄
model PointsLog {
  id     Int @id @default(autoincrement()) @map("points_log_id")
  type   Int
  userId Int @map("user_id")
  amount Int

  createdAt DateTime @default(now()) @map("created_at") // 💡 修正：添加時間戳記

  User User @relation(fields: [userId], references: [id])

  @@map("points_logs")
}

//登入紀錄
model LoginLog {
  id        Int      @id @default(autoincrement()) @map("login_log_id")
  userId    Int      @map("user_id")
  loginTime DateTime @default(now()) @map("login_time") // 💡 修正：添加 @default(now())
  status    Int

  User User @relation(fields: [userId], references: [id])

  @@map("login_logs")
}
